# =============================================================
# BI Platform — .gitignore
# =============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
.pytype/

# --- Environment variables (NEVER commit secrets) ---
.env
.env.local
.env.*.local
*.env

# --- Node / Next.js ---
node_modules/
.next/
out/
.npm
.yarn/

# Next.js build output
frontend/.next/
frontend/out/

# --- Database ---
*.sqlite
*.sqlite3
*.db

# --- PDF reports (generated at runtime) ---
/tmp/bi_reports/
*.pdf

# --- Logs ---
*.log
logs/
uvicorn.log

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*.DS_Store
Thumbs.db

# --- Docker ---
docker-compose.override.yml

# --- Misc ---
*.zip
*.tar.gz
.cache/